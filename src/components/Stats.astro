---
import { siteConfig } from "../config";
---

<section id="stats" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50 border-t border-gray-100">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
    <div class="lg:col-span-4">
      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Live Stats
      </h2>
      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      />
    </div>

    <div class="lg:col-span-8">
      <div class="space-y-8">
        
        {/* LeetCode Overall Stats */}
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-gray-900">LeetCode Profile</h3>
              <p class="text-base sm:text-lg" style={`color: ${siteConfig.accentColor}`}>ksri_sumit</p>
            </div>
            <span id="leetcode-loading" class="text-sm text-gray-500 mt-2 sm:mt-0">Fetching live data...</span>
          </div>
          
          <div id="leetcode-stats" class="hidden">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Rating</p>
                <p id="lc-rating" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Global Rank</p>
                <p id="lc-ranking" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Top %</p>
                <p id="lc-top" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Contests</p>
                <p id="lc-contests" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
            </div>
          </div>
        </div>

        {/* LeetCode Charts (Heatmap + Line Graph) */}
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300 overflow-hidden">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-gray-900">Activity & Ratings</h3>
            </div>
            <div id="lc-charts-loading" class="text-sm text-gray-500">Loading graphs...</div>
          </div>
          
          <div id="lc-charts-container" class="hidden flex flex-col gap-8 w-full mt-6">
            <div>
              <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">Submission Heatmap (Past Year)</h4>
              <div id="lc-heatmap" class="w-full h-[200px]"></div>
            </div>
            <div>
              <h4 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">Contest Rating History</h4>
              <div id="lc-rating-graph" class="w-full h-[300px]"></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Include Apache ECharts from CDN -->
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>

<script>
  async function fetchLeetCodeData() {
    try {
      // Fetch both APIs in parallel
      const [contestRes, calendarRes] = await Promise.all([
        fetch('https://alfa-leetcode-api.onrender.com/ksri_sumit/contest'),
        fetch('https://alfa-leetcode-api.onrender.com/ksri_sumit/calendar')
      ]);
      
      const contestData = await contestRes.json();
      const calendarData = await calendarRes.json();
      
      // 1. Update Stat Cards
      if (contestData && contestData.contestRating) {
        document.getElementById('lc-rating').textContent = Math.round(contestData.contestRating).toString();
        document.getElementById('lc-ranking').textContent = contestData.contestGlobalRanking.toLocaleString();
        document.getElementById('lc-top').textContent = contestData.contestTopPercentage + '%';
        document.getElementById('lc-contests').textContent = contestData.contestAttend.toString();
        
        document.getElementById('leetcode-loading').classList.add('hidden');
        document.getElementById('leetcode-stats').classList.remove('hidden');
      }

      // Initialize ECharts instances
      const heatmapChart = echarts.init(document.getElementById('lc-heatmap'));
      const ratingChart = echarts.init(document.getElementById('lc-rating-graph'));

      // 2. Prepare Heatmap Data
      if (calendarData && calendarData.submissionCalendar) {
        const calMap = JSON.parse(calendarData.submissionCalendar);
        const heatmapPoints = [];
        
        for (const [timestamp, count] of Object.entries(calMap)) {
          const date = new Date(parseInt(timestamp) * 1000);
          const dateString = date.toISOString().split('T')[0];
          heatmapPoints.push([dateString, count]);
        }

        const todayDate = new Date();
        const oneYearAgoDate = new Date();
        oneYearAgoDate.setFullYear(todayDate.getFullYear() - 1);
        
        const today = todayDate.toISOString().split('T')[0];
        const oneYearAgo = oneYearAgoDate.toISOString().split('T')[0];

        heatmapChart.setOption({
          tooltip: {
            position: 'top',
            formatter: function(p) {
              const count = p.data[1] || 0;
              return `${count} submissions on ${p.data[0]}`;
            }
          },
          visualMap: {
            show: false,
            min: 0,
            max: 15,
            type: 'piecewise',
            pieces: [
              {value: 0, color: '#ebedf0'},
              {min: 1, max: 2, color: '#9be9a8'},
              {min: 3, max: 5, color: '#40c463'},
              {min: 6, max: 10, color: '#30a14e'},
              {min: 11, color: '#216e39'}
            ]
          },
          calendar: {
            top: 30, left: 30, right: 10, bottom: 10,
            cellSize: ['auto', 15],
            range: [oneYearAgo, today],
            itemStyle: { borderWidth: 3, borderColor: '#fff' },
            yearLabel: { show: false },
            splitLine: { show: false },
            dayLabel: { nameMap: ['S', 'M', 'T', 'W', 'T', 'F', 'S'], color: '#7a7a7a' },
            monthLabel: { color: '#7a7a7a' }
          },
          series: {
            type: 'heatmap',
            coordinateSystem: 'calendar',
            data: heatmapPoints
          }
        });
      }

      // 3. Prepare Rating Graph Data
      if (contestData && contestData.contestParticipation) {
        const ratingPoints = [];
        contestData.contestParticipation.forEach(c => {
          const date = new Date(c.contest.startTime * 1000).toISOString().split('T')[0];
          ratingPoints.push([date, Math.round(c.rating)]);
        });

        ratingChart.setOption({
          tooltip: { trigger: 'axis', formatter: '{b} <br/> Rating: {c}' },
          grid: { top: 10, left: 40, right: 20, bottom: 30 },
          xAxis: { 
            type: 'time', 
            splitLine: { show: false },
            axisLine: { lineStyle: { color: '#ccc' } },
            axisLabel: { color: '#7a7a7a' }
          },
          yAxis: { 
            type: 'value', 
            min: 'dataMin',
            splitLine: { lineStyle: { color: '#f0f0f0' } },
            axisLabel: { color: '#7a7a7a' }
          },
          series: [{
            type: 'line',
            data: ratingPoints,
            smooth: true,
            lineStyle: { color: '#f59e0b', width: 3 },
            itemStyle: { color: '#f59e0b' },
            areaStyle: {
              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                { offset: 0, color: 'rgba(245, 158, 11, 0.4)' },
                { offset: 1, color: 'rgba(245, 158, 11, 0.05)' }
              ])
            }
          }]
        });
      }

      document.getElementById('lc-charts-loading').classList.add('hidden');
      document.getElementById('lc-charts-container').classList.remove('hidden');

      // Make charts responsive
      window.addEventListener('resize', () => {
        heatmapChart.resize();
        ratingChart.resize();
      });

    } catch (error) {
      document.getElementById('lc-charts-loading').textContent = 'Error fetching graphs.';
      console.error('Error fetching LeetCode data:', error);
    }
  }

  // Execute on load
  document.addEventListener('DOMContentLoaded', fetchLeetCodeData);
</script>

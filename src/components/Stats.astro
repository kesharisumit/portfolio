---
import { siteConfig } from "../config";
---

<section id="stats" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50 border-t border-gray-100">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
    <div class="lg:col-span-4">
      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
        Live Stats
      </h2>
      <div
        class="w-[75px] h-[5px] mt-2 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      />
    </div>

    <div class="lg:col-span-8">
      <div class="space-y-8">
        
        {/* LeetCode Stats */}
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-gray-900">LeetCode Rating</h3>
              <p class="text-base sm:text-lg" style={`color: ${siteConfig.accentColor}`}>ksri_sumit</p>
            </div>
            <span id="leetcode-loading" class="text-sm text-gray-500 mt-2 sm:mt-0">Fetching live data...</span>
          </div>
          
          <div id="leetcode-stats" class="hidden">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4">
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Rating</p>
                <p id="lc-rating" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Global Rank</p>
                <p id="lc-ranking" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Top %</p>
                <p id="lc-top" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
              <div class="p-4 bg-gray-50 rounded-lg border border-gray-100 text-center">
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold">Contests</p>
                <p id="lc-contests" class="text-2xl font-bold text-gray-900 mt-1">--</p>
              </div>
            </div>
          </div>
        </div>

        {/* LeetCode Submission Graph */}
        <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300 overflow-hidden">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
            <div>
              <h3 class="text-lg sm:text-xl font-semibold text-gray-900">LeetCode Submissions</h3>
              <p class="text-base sm:text-lg" style={`color: ${siteConfig.accentColor}`}>ksri_sumit</p>
            </div>
            <div id="lc-heatmap-loading" class="text-sm text-gray-500">Loading graph...</div>
          </div>
          
          {/* Heatmap Container */}
          <div class="mt-4 pb-4 w-full">
            <div id="lc-heatmap-container" class="hidden flex flex-col items-start gap-1 w-full">
              {/* The grid will be injected here */}
              <div id="lc-heatmap-grid" class="grid gap-1 w-full" style="grid-template-columns: repeat(53, 1fr);"></div>
              {/* Months labels */}
              <div id="lc-heatmap-months" class="flex text-xs text-gray-500 mt-1 w-full relative h-4"></div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  // Fetch LeetCode Contest Stats
  async function fetchLeetCodeStats() {
    try {
      const response = await fetch('https://alfa-leetcode-api.onrender.com/ksri_sumit/contest');
      const data = await response.json();
      
      if (data && data.contestRating) {
        document.getElementById('lc-rating').textContent = Math.round(data.contestRating).toString();
        document.getElementById('lc-ranking').textContent = data.contestGlobalRanking.toLocaleString();
        document.getElementById('lc-top').textContent = data.contestTopPercentage + '%';
        document.getElementById('lc-contests').textContent = data.contestAttend.toString();
        
        document.getElementById('leetcode-loading').classList.add('hidden');
        document.getElementById('leetcode-stats').classList.remove('hidden');
      } else {
        document.getElementById('leetcode-loading').textContent = 'Unable to load rating at this time.';
      }
    } catch (error) {
      document.getElementById('leetcode-loading').textContent = 'Error fetching live stats.';
      console.error('Error fetching LeetCode stats:', error);
    }
  }

  // Fetch and Render LeetCode Heatmap
  async function fetchLeetCodeHeatmap() {
    try {
      const response = await fetch('https://alfa-leetcode-api.onrender.com/ksri_sumit/calendar');
      const data = await response.json();
      
      if (data && data.submissionCalendar) {
        const calData = JSON.parse(data.submissionCalendar);
        
        // Map timestamps to dates
        const submissionsByDate = new Map();
        for (const [timestamp, count] of Object.entries(calData)) {
          // timestamp is string, convert to int, multiply by 1000 for ms
          const date = new Date(parseInt(timestamp) * 1000);
          const dateString = date.toISOString().split('T')[0];
          submissionsByDate.set(dateString, count);
        }
        
        renderHeatmap(submissionsByDate);
        
        document.getElementById('lc-heatmap-loading').classList.add('hidden');
        document.getElementById('lc-heatmap-container').classList.remove('hidden');
      } else {
        document.getElementById('lc-heatmap-loading').textContent = 'Unable to load submission graph.';
      }
    } catch (error) {
      document.getElementById('lc-heatmap-loading').textContent = 'Error fetching submission graph.';
      console.error('Error fetching LeetCode calendar:', error);
    }
  }

  function renderHeatmap(submissionsByDate) {
    const grid = document.getElementById('lc-heatmap-grid');
    const monthsContainer = document.getElementById('lc-heatmap-months');
    grid.innerHTML = '';
    monthsContainer.innerHTML = '';
    
    // We want 52 weeks (364 days). Let's go back 364 days from today.
    const today = new Date();
    const daysToGenerate = 365;
    const startDate = new Date(today);
    startDate.setDate(today.getDate() - daysToGenerate + 1);
    
    // Adjust start date to previous Sunday so the grid aligns to a 7-day week
    const startDayOfWeek = startDate.getDay();
    startDate.setDate(startDate.getDate() - startDayOfWeek);
    
    const totalDays = Math.round((today - startDate) / (1000 * 60 * 60 * 24)) + 1;
    const totalColumns = Math.ceil(totalDays / 7);
    
    // Set dynamic columns in case it's 52 or 53
    grid.style.gridTemplateColumns = `repeat(${totalColumns}, 1fr)`;
    
    const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    let lastMonth = -1;
    
    let currentColumn = 0;
    
    for (let i = 0; i < totalDays; i++) {
      const currentDate = new Date(startDate);
      currentDate.setDate(startDate.getDate() + i);
      
      const dateString = currentDate.toISOString().split('T')[0];
      const count = submissionsByDate.get(dateString) || 0;
      
      const cell = document.createElement('div');
      // Use aspect-square so it scales proportionally with width
      cell.className = 'w-full aspect-square rounded-sm';
      cell.title = `${count} submissions on ${dateString}`;
      
      // Determine color
      if (count === 0) {
        cell.classList.add('bg-gray-200');
      } else if (count <= 2) {
        cell.classList.add('bg-green-300');
      } else if (count <= 5) {
        cell.classList.add('bg-green-500');
      } else if (count <= 10) {
        cell.classList.add('bg-green-600');
      } else {
        cell.classList.add('bg-green-800');
      }
      
      grid.appendChild(cell);
      
      // Handle month labels
      if (currentDate.getDay() === 0) { // Sunday, start of a new column
        if (currentDate.getMonth() !== lastMonth) {
          lastMonth = currentDate.getMonth();
          const monthLabel = document.createElement('div');
          monthLabel.textContent = monthNames[lastMonth];
          monthLabel.style.position = 'absolute';
          // Use percentage to align perfectly with the responsive grid
          monthLabel.style.left = `${(currentColumn / totalColumns) * 100}%`;
          monthsContainer.appendChild(monthLabel);
        }
        currentColumn++;
      }
    }
  }

  // Execute on load
  document.addEventListener('DOMContentLoaded', () => {
    fetchLeetCodeStats();
    fetchLeetCodeHeatmap();
  });
</script>
